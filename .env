# CedarGraph Local Development Environment Configuration
# 适用于当前 macOS 开发环境

# ============================================================================
# 版本配置
# ============================================================================
CEDAR_VERSION=latest

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=DEBUG
LOG_DIR=./logs

# ============================================================================
# 数据目录
# ============================================================================
DATA_DIR=./data

# ============================================================================
# 端口配置 (本地开发使用非标准端口避免冲突)
# ============================================================================
META_PORT=19559
STORAGE_PORT=19779
GRAPH_PORT=19669
QUERY_PORT=19889
PROMETHEUS_PORT=19090
GRAFANA_PORT=13000
ALERTMANAGER_PORT=19093

# ============================================================================
# TTL 配置 (开发环境禁用)
# ============================================================================
TTL_ENABLED=false
TTL_RETENTION_DAYS=7

# ============================================================================
# 监控配置
# ============================================================================
GRAFANA_PASSWORD=cedar123

# ============================================================================
# 性能配置 (开发环境使用较低配置)
# ============================================================================
# StorageD
STORAGE_IO_THREADS=2
STORAGE_WORKER_THREADS=4
STORAGE_MEMTABLE_SIZE=32MB

# GraphD
GRAPH_QUERY_TIMEOUT=60000
GRAPH_MAX_CONNECTIONS=100

# MetaD
META_ELECTION_TIMEOUT=2000
META_HEARTBEAT_INTERVAL=200

# ============================================================================
# 备份配置
# ============================================================================
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=cedar-backups

# ============================================================================
# 告警配置
# ============================================================================
ALERT_EMAIL=
ALERT_SLACK_WEBHOOK=
