# CedarGraph Local Development Environment Configuration
# 适用于当前 macOS 开发环境

# ============================================================================
# 版本配置
# ============================================================================
CEDAR_VERSION=k8s-fix-20260630

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=DEBUG
LOG_DIR=./logs

# ============================================================================
# 数据目录
# ============================================================================
DATA_DIR=./data

# ============================================================================
# 端口配置
# 这些变量会被 docker-compose.production.yml 自动读取，因此默认值必须
# 与生产文档和健康检查保持一致。需要避开本机端口冲突时，请在临时
# shell 中覆盖，或使用 preflight 脚本自己的 CEDAR_PREFLIGHT_* 端口变量。
# ============================================================================
META_PORT=9559
META_GRPC_PORT=10559
STORAGE_PORT=9779
GRAPH_PORT=9669
GRAPH_HEALTH_PORT=9668
GRAPH_METRICS_PORT=9667
QUERY_PORT=9889
PROMETHEUS_PORT=19090
GRAFANA_PORT=13000
ALERTMANAGER_PORT=19093

# ============================================================================
# TTL 配置 (开发环境禁用)
# ============================================================================
TTL_ENABLED=false
TTL_RETENTION_DAYS=7

# ============================================================================
# 监控配置
# ============================================================================
# 生产部署必须通过环境变量或 Secret 管理系统显式提供。
# GRAFANA_PASSWORD=replace-with-strong-grafana-password

# ============================================================================
# 性能配置 (开发环境使用较低配置)
# ============================================================================
# StorageD
STORAGE_IO_THREADS=2
STORAGE_WORKER_THREADS=4
STORAGE_MEMTABLE_SIZE=32MB

# GraphD
GRAPH_QUERY_TIMEOUT=60000
GRAPH_MAX_CONNECTIONS=100

# MetaD
META_ELECTION_TIMEOUT=2000
META_HEARTBEAT_INTERVAL=200

# ============================================================================
# 备份配置
# ============================================================================
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=cedar-backups

# ============================================================================
# 告警配置
# ============================================================================
ALERT_EMAIL=
ALERT_SLACK_WEBHOOK=
